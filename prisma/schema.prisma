generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  EXHIBITOR
  SPONSOR
  ADMIN
}

enum BoothStatus {
  AVAILABLE
  RESERVED
  PAYMENT_SUBMITTED
  CONFIRMED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

enum InvoiceStatus {
  UNPAID
  PENDING_VERIFICATION
  PAID
  REJECTED
}

enum PaymentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  MPESA
  BANK
  OTHER
}

enum SponsorLevel {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

enum BoothAudience {
  EXHIBITOR
  SPONSOR
}

enum ExhibitorCategory {
  AGRICULTURAL_MACHINERY                  @map("agricultural-machinery")
  CROPS_AND_SEEDS                         @map("crops-and-seeds")
  LIVESTOCK_AND_ANIMAL_PRODUCTION         @map("livestock-and-animal-production")
  FOOD_AND_AGRO_PROCESSING                @map("food-and-agro-processing")
  AGRIBUSINESS_FINANCE_AND_INSURANCE      @map("agribusiness-finance-and-insurance")
  REGULATORY_RESEARCH_AND_LEARNING_INSTITUTIONS @map("regulatory-research-and-learning-institutions")
  COOPERATIVES_MSMES_NGOS_AND_CBOS        @map("cooperatives-msmes-ngos-and-cbos")
  ENVIRONMENT_AND_CLIMATE_SMART_SOLUTIONS @map("environment-and-climate-smart-solutions")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(EXHIBITOR)
  companyName   String
  phone         String
  logoUrl       String?
  description   String?  @db.Text
  website       String?
  category      ExhibitorCategory?
  exhibitorCategory ExhibitorCategory?
  sponsorLevel  SponsorLevel?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservations Reservation[]
  invoices     Invoice[]
  booths       Booth[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Booth {
  id           String      @id @default(cuid())
  name         String      @unique
  section      String
  audience     BoothAudience @default(EXHIBITOR)
  sponsorLevel SponsorLevel?
  price        Decimal     @db.Decimal(10, 2)
  status       BoothStatus @default(AVAILABLE)
  reservedBy   String?
  reservedUntil DateTime?
  user         User?       @relation(fields: [reservedBy], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reservations Reservation[]
  invoiceItems InvoiceItem[]
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  boothId   String
  invoiceId String?
  status    ReservationStatus @default(PENDING)
  user      User              @relation(fields: [userId], references: [id])
  booth     Booth             @relation(fields: [boothId], references: [id])
  invoice   Invoice?          @relation(fields: [invoiceId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  userId        String
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(UNPAID)
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items        InvoiceItem[]
  payments     Payment[]
  reservations Reservation[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  boothId   String
  price     Decimal @db.Decimal(10, 2)
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  booth     Booth   @relation(fields: [boothId], references: [id])
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  method          PaymentMethod
  transactionCode String?
  proofImageUrl   String?
  notes           String?       @db.Text
  status          PaymentStatus @default(SUBMITTED)
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  submittedAt     DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AttendeeRegistration {
  id            String   @id @default(cuid())
  fullName      String
  email         String
  phone         String
  organization  String?
  county        String?
  attendeeType  String
  interests     String?  @db.Text
  notes         String?  @db.Text
  status        String   @default("REGISTERED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model FeedbackSubmission {
  id            String   @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  category      String
  subject       String
  message       String   @db.Text
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
