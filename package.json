{
  "name": "abtf",
  "version": "1.0.0",
  "description": "University of Eldoret Agri-Business Trade Fair Platform",
  "private": true,
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "predev": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "pretypecheck": "npm run prisma:generate",
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --no-hints",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:resolve:baseline": "prisma migrate resolve --applied 20260323000100_baseline_existing_db",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "docx": "^9.5.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "effect": "3.21.0",
    "flatted": "3.4.2"
  }
}
